# Veil Wallet — Environment Variables
# Copy to .env.local and fill in your values

# Factory contract ID on Stellar Testnet
NEXT_PUBLIC_FACTORY_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4

# Network (testnet | mainnet)
NEXT_PUBLIC_NETWORK=testnet

# Agent WebSocket server
NEXT_PUBLIC_AGENT_WS_URL=ws://localhost:3001

# Transak API key for the buy-crypto fiat onramp (issue #117)
# Apply at https://partners.transak.com — free for dev/testnet usage
# If omitted, Transak widget opens without an API key (limited mode)
NEXT_PUBLIC_TRANSAK_API_KEY=
